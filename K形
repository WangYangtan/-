#include<iostream>
using namespace std;
int main(){
    int a;cin>>a;
    int n=a+1;
    for(int i=1;i<a;i++){
        for(int j=1;j<=n;j++){
            if(j==1||j==n-i+1){cout<<"*";}
            else{cout<<" ";}
        }cout<<endl;
    }
    cout<<"*"<<endl;
    for(int i=1;i<a;i++){
        for(int j=1;j<=n;j++){
            if(j==1||j==i+2){cout<<"*";}
            else{cout<<" ";}
        }cout<<endl;
    }
    return 0;
}
