#include<iostream>
#include<vector>
using namespace std;
int h(string a){
    int left=0,right=a.size()-1;
    while(left<right){
        if(a[left]==a[right]){left++;right--;}
        else{return 0;}
    }
    return 1;
}
int main()
{
string a;
cin>>a;
int A=a.size();
if(A<=1){
    cout<<a;
    return 0;
}
string max="";
int lmax=0;
for(int i=0;i<A;i++){
    for(int j=A-1;j>i;j--){
        int l=j-i+1;
        if(l<=lmax)break;
        string t=a.substr(i,l);
if(h(t)==1){
lmax=t.size();
max=t;
}
    }
   }
   cout<<max;
   return 0;
}
