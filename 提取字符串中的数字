#include <iostream>
#include <ctype.h>
#include <string>
using namespace std;
int F(char i)
{
    int m;
    if(i=='0')m=0;
    else if(i=='1')m=1;
    else if(i=='2')m=2;
    else if(i=='3')m=3;
    else if(i=='4')m=4;
    else if(i=='5')m=5;
    else if(i=='6')m=6;
    else if(i=='7')m=7;
    else if(i=='8')m=8;
    else if(i=='9')m=9;
    return m;
}
int main()
{
    string s;
    getline(cin,s);
    int d=0;
    int m=0;
    for(int i=0;i<s.size()+1;i++)
    {
        if(isdigit(s[i])){d=d*10+F(s[i]);m++;}
        else{
if(m>0){cout<<d<<endl;m=0;d=0;}
        }
    }
    return 0;
}
